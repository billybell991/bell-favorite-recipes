{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "permalink" .RelPermalink "categories" .Params.categories "tags" .Params.tags "description" .Params.description "content" (.Plain | truncate 300) "source" .Params.source "image" .Params.image) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}